{
  "threshold": 10,
  "reporters": ["html", "console", "markdown"],
  "path": ["src", "rag-web/src", ".jscpd-extracted"],
  "ignore": [
    "**/.venv/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/__pycache__/**",
    "**/*.min.js",
    "**/components.d.ts"
  ],
  "minLines": 3,
  "minTokens": 25,
  "format": ["python", "typescript", "javascript", "vue", "css"]
}